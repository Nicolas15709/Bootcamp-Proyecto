@model Cromo

<div class="cromo-card">
    <div class="cromo-img-wrap">
        <span class="cromo-numero">#@Model.NumeroCromo.ToString("D3")</span>
        @if (Model.Album?.EdicionEspecial == true)
        {
            <span class="badge badge-dorado position-absolute top-0 end-0 m-2"><i class="bi bi-star-fill"></i></span>
        }
        @if (!string.IsNullOrEmpty(Model.FotoUrl))
        {
            <img src="@Model.FotoUrl" alt="@Model.Jugador?.Nombre" loading="lazy" />
        }
        else
        {
            <i class="bi bi-person-bounding-box text-white-50 display-1"></i>
        }
    </div>
    <div class="cromo-body">
        <div class="cromo-nombre">@Model.Jugador?.Nombre</div>
        <div class="small text-muted mb-1">
            <i class="bi bi-shield-fill"></i> @Model.Equipo?.Nombre
        </div>
        <div class="mb-2">
            <span class="badge badge-azul">@Model.Equipo?.Pais?.Nombre</span>
            <span class="badge bg-secondary">@Model.Edicion</span>
        </div>
        <div class="cromo-valor mb-2">@Model.ValorMercado.ToString("C")</div>
        <div class="mt-auto d-flex gap-1">
            <a asp-controller="Cromos" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-wcs flex-fill"><i class="bi bi-eye"></i></a>
            <a asp-controller="Cromos" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-pencil"></i></a>
            <a asp-controller="Cromos" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger flex-fill"><i class="bi bi-trash"></i></a>
        </div>
    </div>
</div>
