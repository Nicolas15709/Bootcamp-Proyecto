@{
    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string Active(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WCS</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;900&display=swap" rel="stylesheet" />

    <!-- Bootstrap + Icons -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- App styles -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldCupStickers.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Loading bar -->
    <div id="page-bar"></div>

    <header>
        <nav class="navbar navbar-expand-lg wcs-navbar fixed-top" id="mainNavbar">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge">WC</span>
                    <span class="brand-text">STICKER <strong class="brand-gold">MANAGER</strong></span>
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item"><a class="nav-link @Active("Home")"      asp-controller="Home"      asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Paises")"    asp-controller="Paises"    asp-action="Index">Países</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Equipos")"   asp-controller="Equipos"   asp-action="Index">Equipos</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Jugadores")" asp-controller="Jugadores" asp-action="Index">Jugadores</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Cromos")"    asp-controller="Cromos"    asp-action="Index">Cromos</a></li>
                        <li class="nav-item"><a class="nav-link @Active("Albumes")"   asp-controller="Albumes"   asp-action="Index">Álbumes</a></li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <main role="main" class="wcs-main">
        <div class="container">
            <partial name="_AlertMessages" />
            @RenderBody()
        </div>
    </main>

    <footer class="wcs-footer mt-auto">
        <div class="container text-center">
            <span class="footer-logo">WORLD CUP STICKER MANAGER</span>
            <span class="footer-sep ms-2 me-2">—</span>
            <span class="footer-copy">Gestor de Cromos Mundialistas &copy; @DateTime.Now.Year</span>
        </div>
    </footer>

    <!-- Core JS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Animation libs -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js"></script>

    <!-- App JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
