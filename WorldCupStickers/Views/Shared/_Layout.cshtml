@{
    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string Active(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - World Cup Sticker Manager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldCupStickers.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark wcs-navbar fixed-top shadow">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-trophy-fill text-warning"></i>
                    World Cup <span class="text-warning">Sticker</span> Manager
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Paises")" asp-controller="Paises" asp-action="Index">
                                <i class="bi bi-globe-americas"></i> Países
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Equipos")" asp-controller="Equipos" asp-action="Index">
                                <i class="bi bi-shield-fill"></i> Equipos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Jugadores")" asp-controller="Jugadores" asp-action="Index">
                                <i class="bi bi-person-fill"></i> Jugadores
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Cromos")" asp-controller="Cromos" asp-action="Index">
                                <i class="bi bi-card-image"></i> Cromos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Albumes")" asp-controller="Albumes" asp-action="Index">
                                <i class="bi bi-collection-fill"></i> Álbumes
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="wcs-main">
        <div class="container">
            <partial name="_AlertMessages" />
            @RenderBody()
        </div>
    </main>

    <footer class="wcs-footer mt-auto">
        <div class="container text-center py-3">
            <i class="bi bi-trophy-fill text-warning"></i>
            <strong>World Cup Sticker Manager</strong> &mdash; Gestor de Cromos Mundialistas
            <span class="text-secondary">&copy; @DateTime.Now.Year</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
