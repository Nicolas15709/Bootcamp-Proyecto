@{
    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string Active(string c) => string.Equals(controller, c, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — WCS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WorldCupStickers.styles.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg wcs-navbar fixed-top">
            <div class="container">

                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-badge">WC</span>
                    <span>STICKER <span class="brand-word-gold">MANAGER</span></span>
                </a>

                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Menú">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-1">
                        <li class="nav-item">
                            <a class="nav-link @Active("Home")" asp-controller="Home" asp-action="Index">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Paises")" asp-controller="Paises" asp-action="Index">Países</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Equipos")" asp-controller="Equipos" asp-action="Index">Equipos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Jugadores")" asp-controller="Jugadores" asp-action="Index">Jugadores</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Cromos")" asp-controller="Cromos" asp-action="Index">Cromos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @Active("Albumes")" asp-controller="Albumes" asp-action="Index">Álbumes</a>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <main role="main" class="wcs-main">
        <div class="container">
            <partial name="_AlertMessages" />
            @RenderBody()
        </div>
    </main>

    <footer class="wcs-footer mt-auto">
        <div class="container text-center">
            <span class="text-gold fw-bold" style="font-family:var(--font-display);letter-spacing:.06em;">WORLD CUP STICKER MANAGER</span>
            <span class="text-dim ms-2">&mdash; Gestor de Cromos Mundialistas &mdash; &copy; @DateTime.Now.Year</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
