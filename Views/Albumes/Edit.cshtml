@model Album
@{
    ViewData["Title"] = "Editar álbum";
}

<div class="wcs-page-header">
    <h1><i class="bi bi-pencil"></i> Editar álbum</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Volver</a>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Anio" class="form-label"></label>
                    <input asp-for="Anio" class="form-control" />
                    <span asp-validation-for="Anio" class="text-danger"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="CantidadCromos" class="form-label"></label>
                    <input asp-for="CantidadCromos" class="form-control" />
                    <span asp-validation-for="CantidadCromos" class="text-danger"></span>
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input asp-for="EdicionEspecial" class="form-check-input" />
                        <label asp-for="EdicionEspecial" class="form-check-label"></label>
                    </div>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-wcs"><i class="bi bi-save"></i> Guardar cambios</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
