@model IEnumerable<Album>
@{
    ViewData["Title"] = "Álbumes";
}

<div class="wcs-page-header">
    <h1><i class="bi bi-collection-fill"></i> Álbumes</h1>
    <a asp-action="Create" class="btn btn-wcs"><i class="bi bi-plus-circle"></i> Nuevo álbum</a>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-9">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Buscar álbum por nombre..." />
    </div>
    <div class="col-md-3 d-grid d-md-flex gap-2">
        <button type="submit" class="btn btn-outline-wcs"><i class="bi bi-search"></i> Filtrar</button>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Limpiar</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info"><i class="bi bi-info-circle"></i> No se encontraron álbumes.</div>
}
else
{
    <div class="row g-4">
        @foreach (var album in Model)
        {
            var registrados = album.Cromos.Count;
            var total = album.CantidadCromos > 0 ? album.CantidadCromos : 1;
            var progreso = Math.Round((double)registrados / total * 100, 1);
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="fw-bold text-primary mb-0">@album.Nombre</h5>
                            @if (album.EdicionEspecial)
                            {
                                <span class="badge badge-dorado"><i class="bi bi-star-fill"></i> Especial</span>
                            }
                        </div>
                        <p class="text-muted small mb-2"><i class="bi bi-calendar-event"></i> Año @album.Anio</p>
                        <p class="mb-1 small">Cromos registrados: <strong>@registrados / @album.CantidadCromos</strong></p>
                        <div class="progress mb-3" style="height: 18px;">
                            <div class="progress-bar bg-warning text-dark fw-bold" role="progressbar"
                                 style="width: @progreso%;" aria-valuenow="@progreso" aria-valuemin="0" aria-valuemax="100">
                                @progreso%
                            </div>
                        </div>
                        <div class="mt-auto d-flex gap-1">
                            <a asp-action="Details" asp-route-id="@album.Id" class="btn btn-sm btn-outline-wcs flex-fill"><i class="bi bi-eye"></i> Ver</a>
                            <a asp-action="Edit" asp-route-id="@album.Id" class="btn btn-sm btn-outline-primary flex-fill"><i class="bi bi-pencil"></i></a>
                            <a asp-action="Delete" asp-route-id="@album.Id" class="btn btn-sm btn-outline-danger flex-fill"><i class="bi bi-trash"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
